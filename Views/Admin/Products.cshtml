@inject IViewLocalizer Localizer
@model List<Product>

@{
    ViewBag.Title = Localizer["PageTitle"];
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="panel panel-default">
        <div class="panel-heading">
            <h1>@Localizer["PageTitle"]</h1>
            <p>@string.Format(Localizer["TotalWorks"].Value, Model.Count())</p>
            <p>@Html.ActionLink(Localizer["AddWork"].Value, "CreateProduct", "Admin", new { @class = "btn btn-success" })</p>
        </div>
        <div class="panel-body">
            <table class="table table-striped table-bordered">
                <tr>
                    <th style="width:15%;">@Localizer["Id"]</th>
                    <th style="width:15%;">@Localizer["Name"]</th>
                    <th style="width:15%;">@Localizer["Category"]</th>
                    <th style="width:15%;">@Localizer["BigImage"]</th>
                    <th style="width:15%;">@Localizer["SmallImage"]</th>
                    <th style="width:25%;">@Localizer["Actions"]</th>
                </tr>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Id</td>
                        <td>@product.Name</td>
                        <td>@product.Category</td>
                        <td>
                            @if (product.BigImage == null)
                            {
                                <p>@Localizer["NoImageAdded"]</p>
                            }
                            else
                            {
                                <img src="@product.BigImage" width="192" height="108" alt="product"/>
                            }
                        </td>
                        <td>
                            @if (product.SmallImage == null)
                            {
                                <p>@Localizer["NoImageAdded"]</p>
                            }
                            else
                            {
                                <img src="@product.SmallImage" width="192" height="108" alt="product"/>
                            }
                        </td>
                        <td>
                            @Html.ActionLink(Localizer["Edit"].Value, "EditProduct", new { id = product.Id }, new { @class = "btn btn-success" })
                            @using (Html.BeginForm("DeleteProduct", "Admin", FormMethod.Post))
                            {
                                @Html.Hidden("id", product.Id)
                                <input type="submit" class="btn btn-danger" value="@Localizer["Delete"]"/>
                            }
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
</div>