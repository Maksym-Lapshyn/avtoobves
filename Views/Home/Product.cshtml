@model Product

@{
    ViewBag.Title = string.Format(L["PageTitle_Product"].Value, Model.LocalizedName());
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categoryName = Model.Category.ToString() switch
    {
        "Front" => L["Cat_Front"].Value,
        "Rear" => L["Cat_Rear"].Value,
        "Footer" => L["Cat_Footer"].Value,
        _ => L["Cat_Other"].Value
    };
}

<section class="site-content categories product">
    <div class="container">
        <div class="row">
            <div class="visible-lg visible-md col-md-7">
                <a id="single-image" href="@Model.BigImage">
                    <img src="@Model.BigImage" alt="@Model.LocalizedName()" name="@Model.LocalizedName()" class="img-responsive">
                </a>
            </div>
            <div class="visible-sm visible-xs text-center">
                <img src="@Model.BigImage" alt="@Model.LocalizedName()" name="@Model.LocalizedName()" class="img-responsive">
            </div>
            <div class="col-md-5 wow fadeInRight delay-01s">
                <h1>@Model.LocalizedName()</h1>
                <hr class="visible-md visible-lg"/>
                <hr class="hr-center visible-sm visible-xs"/>
                <h3>@L["Product_Category"] - @Html.ActionLink(categoryName, "Category", "Home", new { categoryName = Model.Category.ToString() }, new { @class = "anchor-standard" })</h3>
                <p>@Model.LocalizedDescription()</p>
            </div>
        </div>
        <h3 class="text-center">@L["Product_SimilarWorks"]</h3>
        <hr class="hr-center"/>
        @await Component.InvokeAsync("SimilarProducts", new { productId = Model.Id })
    </div>
</section>

<script>
    $(document).ready(function () {
        $('#single-image').vanillabox({
        });
    });
</script>