@model Product

@{
    ViewBag.Title = $"{Localizer["PageTitlePrefix"].Value} {Model.Name}";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categoryName = Model.Category.ToString() switch
    {
        "Front" => Localizer["CategoryFront"],
        "Rear" => Localizer["CategoryRear"],
        "Footer" => Localizer["CategoryFooter"],
        _ => Localizer["CategoryOther"]
    };
    
    var currentPath = Context.Request.Path.Value;
    var currentCulture = currentPath.StartsWith("/uk/") || currentPath == "/uk" ? "uk" : "ru";
}

<section class="site-content categories product">
    <div class="container">
        <div class="row">
            <div class="visible-lg visible-md col-md-7">
                <a id="single-image" href="@Model.BigImage">
                    <img src="@Model.BigImage" alt="@Model.Name" name="@Model.Name" class="img-responsive">
                </a>
            </div>
            <div class="visible-sm visible-xs text-center">
                <img src="@Model.BigImage" alt="@Model.Name" name="@Model.Name" class="img-responsive">
            </div>
            <div class="col-md-5 wow fadeInRight delay-01s">
                <h1>@Model.Name</h1>
                <hr class="visible-md visible-lg"/>
                <hr class="hr-center visible-sm visible-xs"/>
                <h3>@Localizer["CategoryLabel"] <a href="@Url.Action("Category", "Home", new { culture = currentCulture, categoryName = Model.Category.ToString() })" class="anchor-standard">@categoryName</a></h3>
                <p>@Model.Description</p>
            </div>
        </div>
        <h3 class="text-center">@Localizer["SimilarWorksTitle"]</h3>
        <hr class="hr-center"/>
        @await Component.InvokeAsync("SimilarProducts", new { productId = Model.Id })
    </div>
</section>

<script>
    $(document).ready(function () {
        $('#single-image').vanillabox({});
    });
</script>