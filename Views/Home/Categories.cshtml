@{
    ViewBag.Title = L["PageTitle_Categories"].Value;
    ViewBag.MetaDescription = L["Meta_Description_Categories"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="site-content categories">
    <div class="container">
        <div class="row text-center">
            <div class="col-sm-6 wow fadeInLeft delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Front" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/front.JPG" alt="@L["Cat_Front"]" name="@L["Cat_Front"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@L["Cat_Front"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInRight delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Rear" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/rear.jpg" alt="@L["Cat_Rear"]" name="@L["Cat_Rear"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@L["Cat_Rear"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInLeft delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Footer" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/footer.jpg" alt="@L["Cat_Footer"]" name="@L["Cat_Footer"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@L["Cat_Footer"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInRight delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Other" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/other.jpg" alt="@L["Cat_Other"]" name="@L["Cat_Other"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@L["Cat_Other"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>