@inject IViewLocalizer Localizer

@{
    ViewBag.Title = Localizer["PageTitle"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="site-content categories">
    <div class="container">
        <div class="row text-center">
            <div class="col-sm-6 wow fadeInLeft delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Front" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/front.JPG" alt="@Localizer["CategoryFront"]" name="@Localizer["CategoryFront"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@Localizer["CategoryFront"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInRight delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Rear" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/rear.jpg" alt="@Localizer["CategoryRear"]" name="@Localizer["CategoryRear"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@Localizer["CategoryRear"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInLeft delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Footer" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/footer.jpg" alt="@Localizer["CategoryFooter"]" name="@Localizer["CategoryFooter"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@Localizer["CategoryFooter"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-6 wow fadeInRight delay-05s">
                <a href="@Url.Action("Category", "Home", new { categoryName = "Other" })">
                    <div class="portfolio-box">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/other.jpg" alt="@Localizer["CategoryOther"]" name="@Localizer["CategoryOther"]" class="img-responsive">
                        <div class="portfolio-box-caption">
                            <div class="portfolio-box-caption-content">
                                <h1>@Localizer["CategoryOther"]</h1>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>