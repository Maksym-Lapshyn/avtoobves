@model List<Product>

@{
    var categoryName = Model.First().Category.ToString() switch
    {
        "Front" => Localizer["CategoryFront"],
        "Rear" => Localizer["CategoryRear"],
        "Footer" => Localizer["CategoryFooter"],
        _ => Localizer["CategoryOther"]
    };

    ViewBag.Title = $"{Localizer["PageTitlePrefix"]} {categoryName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var count = 0;
    var currentPath = Context.Request.Path.Value;
    var currentCulture = currentPath.StartsWith("/uk/") || currentPath == "/uk" ? "uk" : "ru";
}

<section class="site-content categories">
    <div class="container">
        <div class="row">
            @foreach (var product in Model)
            {
                if (count == 3)
                {
                    count = 0;
                }

                if (count == 0)
                {
                    <div class="col-md-4 col-xs-6 wow fadeInLeft delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else if (product == Model[1])
                {
                    <div class="col-md-4 col-xs-6 wow fadeInDown delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else if (product != Model[1] && product != Model[4] && count == 1)
                {
                    <div class="col-md-4 col-xs-6 wow fadeInUp delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else if (product == Model[^2] && count == 1)
                {
                    <div class="col-md-4 col-xs-6 wow fadeInUp delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else if (product == Model[^1] && count == 1)
                {
                    <div class="col-md-4 col-xs-6 wow fadeInUp delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else if (count == 2)
                {
                    <div class="col-md-4 col-xs-6 wow fadeInRight delay-01s">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else
                {
                    <div class="col-md-4 col-xs-6">
                        <a href="@Url.Action("Product", "Home", new { culture = currentCulture, productId = product.Id })">
                            <div class="portfolio-box">
                                <img src="@product.SmallImage" alt="@product.Name" name="@product.Name" class="img-responsive">
                                <div class="portfolio-box-caption">
                                    <div class="portfolio-box-caption-content">
                                        <h1>@product.Name</h1>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                count++;
            }
        </div>
    </div>
</section>