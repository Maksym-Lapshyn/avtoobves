@{
    ViewBag.Title = L["PageTitle_Home"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="welcome">
    <div class="container text-center">
        <div class="text-welcome wow fadeInUp delay-01s">
            <h3 class="title">@L["Index_BrandTitle"]</h3>
            <h1>@L["Index_Subtitle"]</h1>
        </div>
    </div>
</section>

<section class="products">
    <div class="container">
        <div class="row">
            <div class="col-sm-6 wow fadeInLeft delay-01s">
                <div id="carousel" class="carousel slide" data-ride="carousel">
                    <div class="carousel-inner">
                        <div class="item active" data-thumb="0">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_1.jpg">
                        </div>
                        <div class="item" data-thumb="0">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_2.jpg">
                        </div>
                        <div class="item" data-thumb="0">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_3.jpg" alt="product">
                        </div>
                        <div class="item" data-thumb="0">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_4.jpg" alt="product">
                        </div>
                        <div class="item" data-thumb="1">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_5.JPG" alt="product">
                        </div>
                        <div class="item" data-thumb="1">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_6.jpg" alt="product">
                        </div>
                        <div class="item" data-thumb="1">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_7.jpg" alt="product">
                        </div>
                        <div class="item" data-thumb="1">
                            <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_8.jpg" alt="product">
                        </div>
                    </div>
                </div>
                <div class="clearfix">
                    <div id="thumbcarousel" class="carousel slide" data-interval="false">
                        <div class="carousel-inner">
                            <div class="item active">
                                <div data-target="#carousel" data-slide-to="0" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_1.jpg" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="1" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_2.jpg" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="2" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_3.jpg" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="3" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_4.jpg" alt="product">
                                </div>
                            </div><!-- /item -->
                            <div class="item">
                                <div data-target="#carousel" data-slide-to="4" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_5.JPG" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="5" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_6.jpg" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="6" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_7.jpg" alt="product">
                                </div>
                                <div data-target="#carousel" data-slide-to="7" class="thumb">
                                    <img src="https://d1ucqhcti31ovy.cloudfront.net/general/carousel_8.jpg" alt="product">
                                </div>
                            </div><!-- /item -->
                        </div><!-- /carousel-inner -->
                        <a class="left carousel-control" href="#thumbcarousel" role="button" data-slide="prev">
                            <span class="glyphicon glyphicon-chevron-left"></span>
                        </a>
                        <a class="right carousel-control" href="#thumbcarousel" role="button" data-slide="next">
                            <span class="glyphicon glyphicon-chevron-right"></span>
                        </a>
                    </div> <!-- /thumbcarousel -->
                </div><!-- /clearfix -->
            </div> <!-- /col-sm-6 -->
            <div class="col-sm-6 wow fadeInRight delay-01s">
                <h1 class="visible-md visible-lg">@L["Index_StainlessTitle"]</h1>
                <h1 class="text-center visible-sm visible-xs">@L["Index_StainlessTitleSm"]</h1>
                <h3 class="visible-md visible-lg">@L["Index_WhatIsIt"]</h3>
                <h3 class="text-center visible-sm visible-xs">@L["Index_WhatIsIt"]</h3>
                <hr class="visible-md visible-lg"/>
                <hr class="hr-center visible-sm visible-xs"/>
                <p>@L["Index_Para1"]</p>
                <p>@L["Index_Para2"]</p>
                <p>@L["Index_Para3"]</p>
                <p>@L["Index_Para4"]</p>
                <p>@L["Index_Para5"]</p>

            </div> <!-- /col-sm-6 -->
        </div> <!-- /row -->
    </div> <!-- /container -->
</section>

<section class="scroller">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-sm-12 text-center">
                <div class="scroller-text">
                    <h3>@L["Index_CatalogTitle"]</h3>
                    <h1>@L["Index_CatalogDesc"]</h1>
                </div>
            </div>
            <div class="col-lg-6 col-sm-12 text-center">
                <h4>@Html.ActionLink(L["Index_GoToCatalog"].Value, "Categories", new { }, new { @class = "ghost-button" })</h4>
            </div>
        </div>
    </div>
</section>

<section class="benefits">
    <div class="container">
        <div class="row">
            <div class="benefits-wrapper col-md-6 col-xs-12 wow fadeInLeft delay-01s">
                <h1 class="txt-tl">@L["Index_Design"]</h1>
                <div class="benefit">
                    <div class="benefit-left">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/design.png"/>
                    </div>
                    <div class="benefit-right">
                        <p>@L["Index_DesignDesc"]</p>
                    </div>
                </div>
            </div>

            <div class="benefits-wrapper col-md-6 col-xs-12 wow fadeInRight delay-01s">
                <h1 class="txt-tl">@L["Index_Material"]</h1>
                <div class="benefit">
                    <div class="benefit-left">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/material.png"/>
                    </div>
                    <div class="benefit-right">
                        <p>@L["Index_MaterialDesc"]</p>
                    </div>
                </div>
            </div>

            <div class="benefits-wrapper col-md-6 col-xs-12 wow fadeInLeft delay-01s">
                <h1 class="txt-tl">@L["Index_Setup"]</h1>
                <div class="benefit">
                    <div class="benefit-left">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/setup.png"/>
                    </div>
                    <div class="benefit-right">
                        <p>@L["Index_SetupDesc"]</p>
                    </div>
                </div>
            </div>

            <div class="benefits-wrapper col-md-6 col-xs-12 wow fadeInRight delay-01s">
                <h1 class="txt-tl">@L["Index_Repair"]</h1>
                <div class="benefit">
                    <div class="benefit-left">
                        <img src="https://d1ucqhcti31ovy.cloudfront.net/general/repair.png"/>
                    </div>
                    <div class="benefit-right">
                        <p>@L["Index_RepairDesc"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function ($) {
        $('#thumbcarousel').carousel(0);
        var $thumbItems = $('#thumbcarousel .item');
        $('#carousel').on('slide.bs.carousel', function (event) {
            var $slide = $(event.relatedTarget);
            var thumbIndex = $slide.data('thumb');
            var curThumbIndex = $thumbItems.index($thumbItems.filter('.active').get(0));
            if (curThumbIndex > thumbIndex) {
                $('#thumbcarousel').one('slid.bs.carousel', function (event) {
                    $('#thumbcarousel').carousel(thumbIndex);
                });
                if (curThumbIndex === ($thumbItems.length - 1)) {
                    $('#thumbcarousel').carousel('next');
                } else {
                    $('#thumbcarousel').carousel(numThumbItems - 1);
                }
            } else {
                $('#thumbcarousel').carousel(thumbIndex);
            }
        });
    })(jQuery);
</script>